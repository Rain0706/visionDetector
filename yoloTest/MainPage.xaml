<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="yoloTest.MainPage">

    <VerticalStackLayout Spacing="10" Padding="20">
        <Label Text="障礙物辨識系統" FontSize="24" HorizontalOptions="Center" />

        <toolkit:CameraView x:Name="cameraView" 
                            WidthRequest="450" 
                            HeightRequest="500"
                            HorizontalOptions="Center" />

        <Button Text="開始辨識" Clicked="OnStartDetectionClicked" />

        <Label x:Name="ResultLabel" Text="辨識結果：等待中..." FontSize="18" />
    </VerticalStackLayout>
</ContentPage>